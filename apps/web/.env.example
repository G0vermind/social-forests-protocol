# =============================================================================
# Social Forests Protocol — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# x402 Payment Protocol
NEXT_PUBLIC_X402_PAY_TO=G...YOUR_TREASURY_ADDRESS
NEXT_PUBLIC_X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_FACILITATOR_API_KEY=your_api_key_from_channels.openzeppelin.com

# Oracle Service (server-side only — NEVER prefix with NEXT_PUBLIC_)
ORACLE_SECRET_KEY=S...YOUR_ORACLE_STELLAR_SECRET
ORACLE_API_KEY=your_random_api_key_for_oracle_auth

# Fee-Bump Relayer (server-side only — pays gas for users)
RELAYER_SECRET_KEY=S...YOUR_RELAYER_STELLAR_SECRET
RELAYER_API_KEY=optional_api_key_for_relayer_auth

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
