# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Rust / Soroban ───────────────────────────────────────────
target/
*.wasm
# Cargo.lock is kept at workspace root (do NOT ignore)

# ── Next.js (apps/web) ───────────────────────────────────────
apps/web/.next/
apps/web/out/
apps/web/build/
apps/web/node_modules/
apps/web/.pnp
apps/web/.pnp.*
apps/web/.yarn/*
!apps/web/.yarn/patches
!apps/web/.yarn/plugins
!apps/web/.yarn/releases
!apps/web/.yarn/versions
apps/web/coverage/
apps/web/next-env.d.ts
apps/web/*.tsbuildinfo

# ── Services ─────────────────────────────────────────────────
services/*/node_modules/
services/*/.env
services/*/.env.*

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env*.local
*.pem

# ── Debug logs ───────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ─────────────────────────────────────────────────────
.DS_Store
.vercel
node_modules
